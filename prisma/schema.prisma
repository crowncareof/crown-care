// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("collaborator")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Service {
  id            Int           @id @default(autoincrement())
  title         String
  description   String
  imageUrl      String?
  imagePublicId String?
  price         String?
  duration      String?
  featured      Boolean       @default(false)
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
}

model Portfolio {
  id             Int      @id @default(autoincrement())
  title          String
  description    String?
  beforeUrl      String
  beforePublicId String?
  afterUrl       String
  afterPublicId  String?
  category       String?
  featured       Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  rating    Int      @default(5)
  comment   String
  avatarUrl String?
  featured  Boolean  @default(true)
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id               Int           @id @default(autoincrement())
  // Contact
  name             String
  email            String?
  phone            String?
  address          String?
  preferredContact String        @default("whatsapp")
  // Furniture
  furnitureType    String?
  fabricType       String?
  hasPets          Boolean       @default(false)
  hasChildren      Boolean       @default(false)
  protectionApplied Boolean      @default(false)
  // Message / notes
  message          String?
  service          String?
  // Pipeline
  status           String        @default("new_lead")
  source           String        @default("website")
  lastServiceDate  DateTime?
  totalServices    Int           @default(0)
  totalRevenue     Float         @default(0)
  serviceValue     Float?
  // Internal (never public)
  clientProfile    String?
  satisfactionScore Int?
  internalFlags    String?
  privateNote      String?
  // Photos
  beforePhotoUrl   String?
  afterPhotoUrl    String?
  // Relations
  appointments     Appointment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Appointment {
  id                Int      @id @default(autoincrement())
  clientName        String
  clientEmail       String?
  clientPhone       String?
  serviceId         Int?
  service           Service? @relation(fields: [serviceId], references: [id])
  leadId            Int?
  lead              Lead?    @relation(fields: [leadId], references: [id])
  scheduledDate     DateTime
  estimatedDuration Int      @default(120)
  address           String?
  status            String   @default("pending")
  notes             String?
  assignedTo        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
